<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.springbootinit.mapper.WlWalletsMapper">

    <resultMap id="BaseResultMap" type="com.springbootinit.model.domain.WlWallets">
            <id property="userId" column="user_id" jdbcType="BIGINT"/>
            <result property="balance" column="balance" jdbcType="DECIMAL"/>
            <result property="frozenBalance" column="frozen_balance" jdbcType="DECIMAL"/>
            <result property="totalIncome" column="total_income" jdbcType="DECIMAL"/>
            <result property="version" column="version" jdbcType="INTEGER"/>
            <result property="updatedAt" column="updated_at" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        user_id,balance,frozen_balance,
        total_income,version,updated_at
    </sql>
</mapper>
