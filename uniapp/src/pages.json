{
   "globalStyle": {
      "navigationBarTextStyle": "black",
      "navigationBarTitleText": "Uni App",
      "navigationBarBackgroundColor": "#F8F8F8",
      "backgroundColor": "#F8F8F8",
      "navigationStyle": "custom",
      "app-plus": {
         "bounce": "none",
         "softinputMode": "adjustResize",
         "inputAccessoryView": false
      }
   },
   "pages": [
      {
         "path": "pages/start/index",
         "name": "start",
         "style": {
            "navigationBarTitleText": "南昌交通学生兼职平台",
            "navigationBarBackgroundColor": "#E7F0FF"
         }
      },
      {
         "path": "pages/tabar/index",
         "name": "tabar",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "主页",
            "navigationBarBackgroundColor": "#E7F0FF"
         }
      },
      {
         "path": "pages/register/index",
         "name": "register",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "注册",
            "navigationBarBackgroundColor": "#E7F0FF"
         }
      },
      {
         "path": "pages/login/index",
         "name": "login",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "登录",
            "navigationBarBackgroundColor": "#E7F0FF"
         }
      },

      {
         "path": "pages/preinfo/index",
         "name": "preinfo",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "用户信息",
            "navigationBarBackgroundColor": "#E7F0FF"
         }
      },

      {
         "path": "pages/tabar/home/details/index",
         "name": "details",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "兼职详情",
            "navigationBarBackgroundColor": "#E7F0FF"
         }
      },

      {
         "path": "pages/tabar/home/prartlst/index",
         "name": "prartlst",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "兼职列表",
            "navigationBarBackgroundColor": "#E7F0FF"
         }
      },

      {
         "path": "pages/tabar/mine/feedback/index",
         "name": "feedback",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "用户反馈",
            "navigationBarBackgroundColor": "#E7F0FF"
         }
      },
      {
         "path": "pages/tabar/mine/uploadresume/index",
         "name": "uploadresume",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "用户上传简历",
            "navigationBarBackgroundColor": "#E7F0FF"
         }
      },

      {
         "path": "pages/tabar/mine/exituser/index",
         "name": "exituser",
         "style": {
            "mp-alipay": {
               "allowsBounceVertical": "NO"
            },
            "navigationStyle": "custom",
            "navigationBarTitleText": "用户信息编辑"
         }
      }
   ],
   "tabBar": {
      "custom": true,
      "selectedColor": "#ffdead",
      "list": [
         {
            "pagePath": "pages/tabar/index",
            "text": "主页"
         }
      ]
   },
   "easycom": {
      "custom": {
         "^(?!z-paging-refresh|z-paging-load-more)z-paging(.*)": "z-paging/components/z-paging$1/z-paging$1.vue",
         "^tn-(.*)-(item|group)$": "@tuniao/tnui-vue3-uniapp/components/$1/src/$1-$2.vue",
         "^tn-(.*)": "@tuniao/tnui-vue3-uniapp/components/$1/src/$1.vue"
      }
   }
}
